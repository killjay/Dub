DATABASE_URL=postgres://user:pass@host/dubkaroo
REDIS_URL=redis://default:pass@host:6379

# Sarvam
SARVAM_API_KEY=
SARVAM_API_BASE=https://api.sarvam.ai

# Replicate
REPLICATE_API_TOKEN=
REPLICATE_MUSETALK_VERSION=

# R2 (same creds as web/, separate to keep workers isolated)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dubkaroo

# Watermark image (PNG with transparency, 1080×1920 friendly)
WATERMARK_PNG=

WORKER_CONCURRENCY=2
